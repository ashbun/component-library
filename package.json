{
  "name": "cc-component-library-monorepo",
  "version": "1.0.0",
  "description": "Component library platform for CC ecommerce - Geist-inspired design system",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/showcase && pnpm run dev",
    "build": "cd packages/showcase && pnpm run build",
    "lint": "cd packages/ui-library && pnpm run lint",
    "type-check": "cd packages/ui-library && pnpm run type-check",
    "sync-tokens": "cd packages/design-tokens && pnpm run sync-figma-tokens"
  },
  "devDependencies": {
    "@storybook/react": "^8.0.0",
    "typescript": "~6.0.2"
  },
  "keywords": [
    "component-library",
    "design-system",
    "react",
    "geist"
  ]
}
