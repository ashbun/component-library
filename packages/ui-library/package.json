{
  "name": "@cc-ecommerce/ui-library",
  "version": "1.0.0",
  "description": "React component library for CC ecommerce platform - Geist-inspired design",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./components": {
      "import": "./src/components/index.ts",
      "types": "./src/components/index.ts"
    },
    "./hooks": {
      "import": "./src/hooks/index.ts",
      "types": "./src/hooks/index.ts"
    },
    "./styles": {
      "import": "./src/styles/globals.css"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@cc-ecommerce/design-tokens": "workspace:*",
    "framer-motion": "^12.38.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~6.0.2",
    "tailwindcss": "^3.4.19"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "geist"
  ]
}
